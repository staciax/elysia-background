{
  "name": "elysia-background",
  "version": "1.3.1",
  "description": "A background task processing plugin for Elysia.js",
  "author": {
    "name": "STACiA",
    "email": "stacia.dev@gmail.com",
    "url": "https://github.com/staciax"
  },
  "bugs": {
    "url": "https://github.com/staciax/elysia-background/issues"
  },
  "homepage": "https://github.com/staciax/elysia-background",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/staciax/elysia-background.git"
  },
  "license": "MIT",
  "keywords": [
    "elysia",
    "background",
    "task",
    "typescript",
    "bun"
  ],
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "scripts": {
    "dev": "bun --bun rolldown -c rolldown.config.ts --watch",
    "build": "bun --bun rolldown -c rolldown.config.ts",
    "test": "bun test",
    "lint": "biome check . && biome format .",
    "lint:ci": "biome ci .",
    "format": "biome check --write . && biome format . --write"
  },
  "devDependencies": {
    "@biomejs/biome": "~2.4.14",
    "@types/bun": "~1.3.11",
    "rolldown": "~1.0.0",
    "rolldown-plugin-dts": "~0.25.0"
  },
  "peerDependencies": {
    "elysia": ">=1.3.0",
    "typescript": "^5"
  },
  "packageManager": "bun@1.3.13"
}
